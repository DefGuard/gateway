<model>
  <mount>//OPNsense/defguardgateway</mount>
  <description>Defguard Gateway plugin for OPNsense</description>
  <items>
    <general>
      <Enabled type="BooleanField">
        <default>0</default>
        <Required>Y</Required>
      </Enabled>
      <Userspace type="BooleanField">
        <default>0</default>
        <Required>Y</Required>
      </Userspace>
      <LogLevel type="TextField">
        <default>info</default>
        <Required>Y</Required>
      </LogLevel>
      <Name type="TextField">
        <Required>N</Required>
      </Name>
      <GrpcPort type="IntegerField">
        <default>50066</default>
        <Required>Y</Required>
      </GrpcPort>
      <UseSyslog type="BooleanField">
        <default>0</default>
        <Required>Y</Required>
      </UseSyslog>
      <PidFile type="TextField">
        <default>/var/run/defguard_gateway.pid</default>
        <Required>N</Required>
      </PidFile>
      <SyslogSocket type="TextField">
        <default>/var/run/log</default>
        <Required>Y</Required>
      </SyslogSocket>
      <SyslogFacility type="TextField">
        <default>LOG_USER</default>
        <Required>Y</Required>
      </SyslogFacility>
      <IfName type="TextField">
        <Required>Y</Required>
        <default>wg0</default>
        <Mask>/^wg[0-9]*$/</Mask>
        <ValidationMessage>please specify a valid interface name starting with wg</ValidationMessage>
      </IfName>
      <StatsPeriod type="IntegerField">
        <Required>Y</Required>
        <default>30</default>
      </StatsPeriod>
      <PreUp type="TextField">
        <Required>N</Required>
      </PreUp>
      <PreDown type="TextField">
        <Required>N</Required>
      </PreDown>
      <PostUp type="TextField">
        <Required>N</Required>
      </PostUp>
      <PostDown type="TextField">
        <Required>N</Required>
      </PostDown>
      <HealthPort type="IntegerField">
        <Required>N</Required>
      </HealthPort>
      <Masquerade type="BooleanField">
        <default>0</default>
        <Required>Y</Required>
      </Masquerade>
      <FwPriority type="IntegerField">
        <Required>N</Required>
      </FwPriority>
      <DisableFirewallManagement type="BooleanField">
        <default>0</default>
        <Required>Y</Required>
      </DisableFirewallManagement>
      <HttpBindAddress type="NetworkField">
        <Required>N</Required>
        <NetMaskAllowed>N</NetMaskAllowed>
        <NetMaskRequired>N</NetMaskRequired>
        <ValidationMessage>please specify a valid IP address</ValidationMessage>
      </HttpBindAddress>
      <CertDir type="TextField">
        <default>/etc/defguard/certs</default>
        <Required>Y</Required>
      </CertDir>
    </general>
  </items>
</model>
